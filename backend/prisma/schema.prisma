generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

enum AvailabilityMode {
  DAILY
  WEEKLY
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id                  Int           @id @default(autoincrement())
  name                String
  email               String        @unique
  password            String
  role                Role
  doctor              Doctor?
  patientAppointments Appointment[] @relation("PatientAppointments")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([role])
}

model Doctor {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique
  specialization     String?
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilityBlocks DoctorAvailability[]
  dayOffs            DoctorDayOff[]
  appointments       Appointment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model DoctorAvailability {
  id        Int              @id @default(autoincrement())
  doctorId  Int
  mode      AvailabilityMode @default(DAILY)
  dayOfWeek Weekday?
  startTime String           @db.VarChar(5)
  endTime   String           @db.VarChar(5)
  doctor    Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([doctorId, mode])
  @@index([doctorId, mode, dayOfWeek, startTime])
}

model DoctorDayOff {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      DateTime @db.Date
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, date])
  @@index([doctorId, date])
}

model Appointment {
  id        Int               @id @default(autoincrement())
  patientId Int
  doctorId  Int
  date      DateTime          @db.Date
  time      String            @db.VarChar(5)
  status    AppointmentStatus @default(BOOKED)
  patient   User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor    Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([doctorId, date])
  @@index([doctorId, date, time])
  @@index([patientId, date])
  @@index([patientId, date, status])
}
